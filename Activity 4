<?php
// ==================================================
// LAB 3: If-ElseIf Statement (Grade Checker)
// ==================================================
echo "<div class='lab-title'><strong>LAB 3: If-ElseIf Statement</strong></div>";
if ($_SERVER["REQUEST_METHOD"] == "POST" && isset($_POST["grade"])) {
    $grade = $_POST["grade"];
    echo "<div class='result'>";
    if ($grade >= 90 && $grade <= 100) {
        echo "Excellent";
    } elseif ($grade >= 80 && $grade <= 89) {
        echo "Good";
    } elseif ($grade >= 70 && $grade <= 79) {
        echo "Average";
    } elseif ($grade < 70 && $grade >= 0) {
        echo "Failed";
    } else {
        echo "Invalid Grade!";
    }
    echo "</div>";
}
?>
<form method="post" action="">
    <label>Enter Student Grade (0-100):</label>
    <input type="number" name="grade" min="0" max="100" required>
    <button type="submit">Check Grade</button>
</form>


